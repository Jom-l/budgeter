# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/budget_computer

# Redis (Memurai)
REDIS_URL=redis://127.0.0.1:6379

# Session
SESSION_SECRET=change-me-to-a-long-random-string

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Outlook SMTP (free)
OUTLOOK_USER=you@outlook.com
OUTLOOK_PASS=your-app-password

# Scheduler (cron time for the daily sweep, server local time)
DAILY_SWEEP_CRON=0 8 * * *
